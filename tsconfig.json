{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": ["raxode-cli/**/*.ts", "raxode-cli/**/*.tsx"],
  "exclude": ["node_modules", "dist", "raxode-cli/frontend/tui/memory/generated/**"]
}
